# Node modules (for both React and Express)
node_modules/

# Build folder (React)
build/

# Environment variables
.env

# Logs
*.log

# OS-specific files
.DS_Store
Thumbs.db
.vercel


# Create .gitignore in your project root
cat > .gitignore << 'EOF'
# Chatbot folder (your specific requirement)
chatbot/
chatbot_node_modules/
chatbot_env/

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.development

# Logs
logs/
*.log
log/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Temporary files
tmp/
temp/
.cache/

# Testing
coverage/
.nyc_output/
*.test.js
*.spec.js

# Debug
debug.log

# Uploads (if any)
uploads/
files/
storage/

# SSL certificates
*.pem
*.key
*.crt

# PM2
.pm2/

# Redis dump
dump.rdb

# Docker
docker-compose.override.yml
*.dockerignore

# Backup files
*.bak
*.backup
*.old

# Config files with secrets
config/local.js
config/production.js
secrets.json
EOF