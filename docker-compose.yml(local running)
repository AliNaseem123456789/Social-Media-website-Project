version: '3.8'

services:
  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: backend-main
    ports:
      - "5000:5000"
    env_file:
      - ./backend/.env
    restart: unless-stopped
    networks:
      - app-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
  email-microservice:
    build:
      context: ./email-microservice
      dockerfile: Dockerfile
    container_name: backend-email
    ports:
      - "5001:5001"
    env_file:
      - ./email-microservice/.env
    restart: unless-stopped
    networks:
      - app-network
    depends_on:
      - backend

  analytics-worker:
    build:
      context: ./backend
      dockerfile: Dockerfile.worker
    container_name: analytics-worker
    env_file:
      - ./backend/.env
    restart: unless-stopped
    networks:
      - app-network
    depends_on:
      backend:
        condition: service_healthy
    command: node workers/analytics-worker.js
  feed-worker:
    build:
      context: ./backend
      dockerfile: Dockerfile.worker
    container_name: feed-worker
    env_file:
      - ./backend/.env
    restart: unless-stopped
    networks:
      - app-network
    depends_on:
      backend:
        condition: service_healthy
    command: node workers/feed-worker.js

networks:
  app-network:
    driver: bridge