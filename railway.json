{
  "build": {
    "builder": "NIXPACKS"
  },
  "services": [
    {
      "name": "backend",
      "root": "backend",
      "buildCommand": "npm install",
      "startCommand": "node server.js",
      "ports": [
        {
          "port": 5000,
          "protocol": "TCP"
        }
      ]
    },
    {
      "name": "email-worker",
      "root": "email-microservice",
      "buildCommand": "npm install",
      "startCommand": "node index.js"
    }
  ]
}